{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "sequoia",
  "name": "Chameleon",
  "description": "Documentation for the Chameleon Discord API framework.",
  "colors": {
    "primary": "#0C8C5E",
    "light": "#2AE5A0",
    "dark": "#0E6B49"
  },
  "appearance": {
    "default": "system"
  },
  "favicon": "/favicon.ico",
  "background": {
    "decoration": "grid",
    "color": {
      "light": "#F7FBF8",
      "dark": "#08130F"
    }
  },
  "fonts": {
    "body": {
      "family": "Manrope",
      "weight": 500
    },
    "heading": {
      "family": "Sora",
      "weight": 700
    }
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    }
  },
  "metadata": {
    "timestamp": true
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "assistant"
    ]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Getting started",
        "groups": [
          {
            "group": "Introduction",
            "pages": [
              "index",
              "getting-started/overview",
              "getting-started/installation",
              "getting-started/quickstart",
              "getting-started/client-setup",
              "getting-started/migrating-from-discordjs"
            ]
          }
        ]
      },
      {
        "tab": "Core concepts",
        "groups": [
          {
            "group": "Framework model",
            "pages": [
              "core-concepts/architecture",
              "core-concepts/store-and-cache",
              "core-concepts/events-and-middleware",
              "core-concepts/rest-result-shape",
              "core-concepts/typing-and-intents"
            ]
          }
        ]
      },
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Bot flows",
            "pages": [
              "guides/slash-commands",
              "guides/patterns-and-pitfalls",
              "guides/commands-and-components",
              "guides/components-v2-and-modals",
              "guides/collectors-and-files",
              "guides/rest-and-managers",
              "guides/message-and-channel-managers",
              "guides/guilds-members-and-roles",
              "guides/webhooks-invites-and-application-flows",
              "guides/debugging-and-sharding",
              "guides/store-tuning"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "Reference",
            "pages": [
              "reference/client-and-runtime-api",
              "reference/commands-components-and-modals-api",
              "reference/managers-api",
              "reference/api-reference",
              "reference/roadmap-and-design",
              "reference/public-surface",
              "reference/current-limitations"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://github.com/ImpulseDoes/chameleon"
  },
  "navbar": {
    "links": [
      {
        "label": "Quickstart",
        "href": "/getting-started/quickstart"
      },
      {
        "label": "Guides",
        "href": "/guides/rest-and-managers"
      },
      {
        "label": "GitHub",
        "href": "https://github.com/ImpulseDoes/chameleon"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Start building",
      "href": "/getting-started/quickstart"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/impulsedoes",
      "github": "https://github.com/ImpulseDoes/chameleon"
    }
  }
}